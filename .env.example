# ─────────────────────────────────────────────
#  AI Workflow Automation — Environment Config
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# [REQUIRED] OpenAI API key (preferred)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# [OPTIONAL] OpenAI model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# [TEMPORARY COMPATIBILITY] Legacy Anthropic key/model fallback
# These are only used if OPENAI_API_KEY is not set.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# [OPTIONAL] Max tokens per LLM call (default: 1500)
MAX_TOKENS=1500

# [OPTIONAL] Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# [OPTIONAL] Application environment
APP_ENV=development

# [OPTIONAL] Comma-separated allowed CORS origins (* = allow all)
CORS_ORIGINS=*
